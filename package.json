{
  "name": "cozycasa",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "expo-router/entry",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev:api": "node --env-file-if-exists=.env --watch src/server.ts",
    "dev:expo": "expo start",
    "build": "expo export --platform web --output-dir dist",
    "start": "node --env-file-if-exists=.env src/server.ts",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc --noEmit",
    "test": "node --test src/server-utils.test.ts src/auth-cors.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "better-auth": "1.6.11",
    "expo": "~55.0.25",
    "expo-router": "~55.0.15",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~55.0.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@playwright/test": "1.49.1",
    "@types/node": "25.8.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "babel-preset-expo": "~14.0.6",
    "typescript": "6.0.3"
  }
}
