{
  "name": "cozycasa",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev:api": "node --env-file-if-exists=.env --watch src/server.ts",
    "dev:web": "vite",
    "build": "tsc -p tsconfig.web.json --noEmit && vite build",
    "start": "node --env-file-if-exists=.env src/server.ts",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.web.json --noEmit"
  },
  "dependencies": {
    "better-auth": "1.6.11",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@types/node": "25.8.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "typescript": "6.0.3",
    "vite": "8.0.13"
  }
}
